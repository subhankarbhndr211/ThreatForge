# ThreatForge Enterprise - Environment Configuration
# Copy this file to .env and fill in your API keys

# Server Configuration
NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# CORS Configuration
CORS_ORIGIN=*

# Rate Limiting
RATE_LIMIT_MAX=100

# Analysis Engine Configuration
ENABLE_AI=true
ENABLE_AUTO_RESPONSE=false
ENABLE_THREAT_INTEL=true
ENABLE_URL_DETONATION=true

# ============================================
# LLM Configuration (OpenAI / Anthropic / Groq)
# ============================================
# Choose provider: openai, anthropic, groq, gemini, mistral, ollama
AI_PROVIDER=groq

# API Keys - add your keys here
GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=
OLLAMA_URL=http://localhost:11434

# Model selection (optional - defaults used if empty)
# Groq: llama-3.3-70b-versatile, mixtral-8x7b-32768
# OpenAI: gpt-4o, gpt-4o-mini, gpt-4-turbo
# Anthropic: claude-3-5-sonnet-20241022, claude-3-opus-20240229
# Gemini: gemini-1.5-flash, gemini-1.5-pro
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_MODEL=gpt-4o
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
GEMINI_MODEL=gemini-1.5-flash

# ============================================
# Threat Intelligence API Keys
# ============================================
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
OTX_API_KEY=
THREATFOX_API_KEY=
GREYNOISE_API_KEY=

# MISP Configuration
MISP_URL=
MISP_API_KEY=

# SOAR Integrations
SPLUNK_HEC_URL=
SPLUNK_HEC_TOKEN=

THEHIVE_URL=
THEHIVE_API_KEY=

AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Grafana (Monitoring)
GRAFANA_PASSWORD=admin

# JWT Configuration (for future auth)
JWT_SECRET=
JWT_EXPIRES_IN=24h
