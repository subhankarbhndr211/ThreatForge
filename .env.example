# ThreatForge Enterprise - Environment Configuration
# Copy this file to .env and fill in your API keys

# Server Configuration
NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# CORS Configuration
CORS_ORIGIN=*

# Rate Limiting
RATE_LIMIT_MAX=100

# Analysis Engine Configuration
ENABLE_AI=true
ENABLE_AUTO_RESPONSE=false
ENABLE_THREAT_INTEL=true
ENABLE_URL_DETONATION=true

# Threat Intelligence API Keys
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
OTX_API_KEY=
THREATFOX_API_KEY=

# MISP Configuration
MISP_URL=
MISP_API_KEY=

# SOAR Integrations
SPLUNK_HEC_URL=
SPLUNK_HEC_TOKEN=

THEHIVE_URL=
THEHIVE_API_KEY=

AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Grafana (Monitoring)
GRAFANA_PASSWORD=admin

# JWT Configuration (for future auth)
JWT_SECRET=
JWT_EXPIRES_IN=24h
