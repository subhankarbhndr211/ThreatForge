          {id:'iis_404',       name:'404 Not Found',          severity:'LOW', threat:'Reconnaissance/Scanning',  mitre:'T1595',    desc:'Mass 404s = web scanner probing for vulnerable paths.'},
          {id:'iis_500',       name:'500 Internal Server Error',severity:'MED',threat:'Exploitation',            mitre:'T1190',    desc:'Server error. May indicate SQL injection, XXE, or RCE attempt.'},
          {id:'iis_webshell',  name:'Webshell Access Pattern',severity:'CRIT',threat:'Webshell/Backdoor',        mitre:'T1505.003',desc:'Unusual file in web root making system calls. cmd.exe parent of w3wp.exe.'},
          {id:'iis_cmdinject', name:'Command Injection Pattern',severity:'CRIT',threat:'Remote Code Execution',  mitre:'T1190',    desc:'Shell metacharacters in URL/POST data. ; | && cmd injection.'},
