// Calculate totals for summary
router.get('/', (req, res) => {
  const summary = {};
  for (const [k,v] of Object.entries(LOG_LIBRARY)) {
    let total = 0;
    for (const cat of Object.values(v.categories||{})) {
      total += (cat.events||[]).length;
    }
    summary[k] = { label: v.label, icon: v.icon, color: v.color, totalEvents: total };
  }
  res.json({ platforms: summary });
});

router.get('/:platform', (req, res) => {
  const p = LOG_LIBRARY[req.params.platform];
  if (!p) return res.status(404).json({ error: 'Platform not found' });
  res.json(p);
});

module.exports = router;
module.exports.LOG_LIBRARY = LOG_LIBRARY;
